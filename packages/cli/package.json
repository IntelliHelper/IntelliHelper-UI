{
  "name": "@intellihelper/cli",
  "version": "0.1.0",
  "description": "Add and update IntelliHelper UI Liquid Glass components, plus an MCP server for AI coding agents",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/IntelliHelper/IntelliHelper-UI.git",
    "directory": "packages/cli"
  },
  "homepage": "https://ui.intellihelper.in",
  "keywords": [
    "intellihelper-ui",
    "intelli-ui",
    "cli",
    "components",
    "react",
    "tailwind",
    "liquid-glass",
    "shadcn",
    "mcp",
    "model-context-protocol"
  ],
  "bin": {
    "intellihelper-ui": "dist/index.js",
    "intelli-ui": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "node scripts/bundle-registry.mjs && node scripts/bundle-mcp-data.mjs",
    "build": "tsc && mkdir -p dist/registry && cp src/registry/bundled.json src/registry/catalog.json src/registry/examples.json src/registry/themes.json dist/registry/",
    "check-types": "pnpm prebuild && tsc --noEmit",
    "dev": "pnpm prebuild && tsc --watch",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.5.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.0",
    "diff": "^8.0.2",
    "picocolors": "^1.1.1",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  }
}